VITE_DATA_SOURCE=auto
VITE_API_BASE_URL=/api
# Vite dev/preview proxy target (Docker Compose sets http://api:3000 on the web service)
# VITE_API_PROXY_TARGET=http://localhost:3000
# Optional: pre-fill admin token for /admin UI (also storable in localStorage)
# VITE_ADMIN_TOKEN=
PORT=3000
# Optional: protect /admin/* API routes (required when PDS_LEDGER_MODE=fabric)
# PDS_ADMIN_TOKEN=
PDS_PERSISTENCE_BACKEND=file
PDS_POSTGRES_DSN=postgresql://pds:pds@localhost:5432/pds_chain
PDS_LEDGER_BACKEND=chaincode-runtime
PDS_FABRIC_CLIENT_ORG=FoodAndCivilSupplies
PDS_STATE_PATH=./tmp/pds-state.json
PDS_LEDGER_JOURNAL_PATH=./tmp/pds-ledger.ndjson
PDS_CHAINCODE_STATE_PATH=./tmp/chaincode-world-state.json
PDS_FABRIC_ENVELOPE_PATH=./tmp/pds-fabric-envelope.ndjson
